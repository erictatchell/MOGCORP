rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdminEmail(email) {
      return email in [
        'erictatch@gmail.com'
      ];
    }

    function isBootstrapAdmin() {
      return isSignedIn() && isBootstrapAdminEmail(request.auth.token.email);
    }

    function userDocPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function userDocExists() {
      return isSignedIn() && exists(userDocPath(request.auth.uid));
    }

    function currentUserRole() {
      return userDocExists()
        ? get(userDocPath(request.auth.uid)).data.role
        : null;
    }

    function isMember() {
      return isSignedIn() && (isBootstrapAdmin() || userDocExists());
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        currentUserRole() == 'admin'
      );
    }

    function isValidRole(role, email) {
      return (
        isBootstrapAdminEmail(email) && role == 'admin'
      ) || (
        !isBootstrapAdminEmail(email) && role in ['friend', 'admin']
      );
    }

    function hasStableIdentity(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.googleName is string
        && request.resource.data.routeId is string
        && request.resource.data.routeId.matches('^[A-Z0-9]{3}$')
        && request.resource.data.photoURL is string;
    }

    function isValidUserState(userId) {
      return hasStableIdentity(userId)
        && request.resource.data.photoStoragePath is string
        && request.resource.data.isAdmin == (request.resource.data.role == 'admin')
        && isValidRole(request.resource.data.role, request.resource.data.email);
    }

    function isValidSelfCreate(userId) {
      return request.auth.uid == userId
        && request.resource.data.email == request.auth.token.email
        && isValidUserState(userId)
        && (
          (isBootstrapAdmin() && request.resource.data.role == 'admin') ||
          (!isBootstrapAdmin() && request.resource.data.role == 'friend')
        );
    }

    function isValidSelfUpdate() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.isAdmin == resource.data.isAdmin
        && request.resource.data.displayName is string
        && request.resource.data.googleName is string
        && request.resource.data.routeId is string
        && request.resource.data.routeId.matches('^[A-Z0-9]{3}$')
        && request.resource.data.photoURL is string
        && request.resource.data.photoStoragePath is string;
    }

    function isValidAdminUpdate(userId) {
      return resource != null
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && (
          request.auth.uid != userId ||
          (
            request.resource.data.role == resource.data.role
            && request.resource.data.isAdmin == resource.data.isAdmin
          )
        )
        && isValidUserState(userId);
    }

    function isValidSiteSettings() {
      return request.resource.data.featuredMessage is string
        && request.resource.data.featuredMessage.size() > 0
        && request.resource.data.featuredMessage.size() <= 180;
    }

    function isValidMemberMediaCreate() {
      return isMember()
        && request.resource.data.kind == 'file'
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.uploadedByUid == request.auth.uid
        && request.resource.data.mimeType is string
        && request.resource.data.downloadURL is string
        && request.resource.data.storagePath is string
        && request.resource.data.authorLabel is string
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorRouteId is string
        && request.resource.data.authorAliasMode == 'self'
        && request.resource.data.authorDisplayName is string
        && request.resource.data.authorGoogleName is string
        && request.resource.data.tripId is string
        && request.resource.data.folderId is string
        && request.resource.data.mediaCategory in ['image', 'video', 'file']
        && request.resource.data.size is number;
    }

    function isValidMemberTextCreate() {
      return isMember()
        && request.resource.data.kind == 'text'
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.name is string
        && request.resource.data.mimeType == 'text/plain'
        && request.resource.data.authorLabel is string
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorRouteId is string
        && request.resource.data.authorAliasMode == 'self'
        && request.resource.data.authorDisplayName is string
        && request.resource.data.authorGoogleName is string
        && request.resource.data.tripId is string
        && request.resource.data.folderId is string;
    }

    function isItemOwner() {
      return isMember()
        && (
          resource.data.createdByUid == request.auth.uid ||
          (
            (resource.data.createdByUid == null || resource.data.createdByUid == '')
            && resource.data.createdByEmail == request.auth.token.email
          )
        );
    }

    function isTextAuthor() {
      return isItemOwner() && resource.data.kind == 'text';
    }

    function isValidMemberTextUpdate() {
      return isTextAuthor()
        && request.resource.data.kind == 'text'
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.name is string
        && request.resource.data.mimeType == 'text/plain'
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.authorLabel == resource.data.authorLabel
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.authorRouteId == resource.data.authorRouteId
        && request.resource.data.authorAliasMode == resource.data.authorAliasMode
        && request.resource.data.authorDisplayName == resource.data.authorDisplayName
        && request.resource.data.authorGoogleName == resource.data.authorGoogleName
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title',
          'body',
          'name',
          'updatedAt',
          'updatedByUid',
          'updatedByEmail'
        ]);
    }

    function isValidMemberFileUpdate() {
      return isItemOwner()
        && resource.data.kind == 'file'
        && request.resource.data.kind == 'file'
        && request.resource.data.description is string
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.authorLabel == resource.data.authorLabel
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.authorRouteId == resource.data.authorRouteId
        && request.resource.data.authorAliasMode == resource.data.authorAliasMode
        && request.resource.data.authorDisplayName == resource.data.authorDisplayName
        && request.resource.data.authorGoogleName == resource.data.authorGoogleName
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'description',
          'updatedAt',
          'updatedByUid',
          'updatedByEmail'
        ]);
    }

    function hasValidSocialAttachmentFields() {
      return request.resource.data.attachmentURL is string
        && request.resource.data.attachmentStoragePath is string
        && request.resource.data.attachmentMimeType is string
        && request.resource.data.attachmentName is string;
    }

    function hasValidSocialContent() {
      return request.resource.data.body is string
        && request.resource.data.body.size() <= 600
        && hasValidSocialAttachmentFields()
        && (
          request.resource.data.body.size() > 0 ||
          request.resource.data.attachmentURL.size() > 0
        );
    }

    function hasValidActivityActorFields() {
      return request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorLabel is string
        && request.resource.data.actorLabel.size() > 0
        && request.resource.data.actorRouteId is string
        && request.resource.data.actorPhotoURL is string;
    }

    function hasValidMediaCommentAuthorFields() {
      return request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorLabel is string
        && request.resource.data.authorLabel.size() > 0
        && request.resource.data.authorRouteId is string
        && request.resource.data.authorPhotoURL is string;
    }

    function hasValidActivityMediaFields() {
      return request.resource.data.tripId is string
        && request.resource.data.folderId is string
        && request.resource.data.itemId is string
        && request.resource.data.itemName is string
        && request.resource.data.sourceLabel is string;
    }

    function isValidActivityCreate(userId) {
      return isMember()
        && request.resource.data.id is string
        && request.resource.data.type in ['wall-post', 'media-comment']
        && hasValidSocialContent()
        && hasValidActivityActorFields()
        && request.resource.data.targetUserUid is string
        && request.resource.data.targetUserLabel is string
        && request.resource.data.createdAtMs is number
        && request.resource.data.createdAtMs > 0
        && (
          (
            request.resource.data.type == 'wall-post'
            && (
              request.resource.data.targetUserUid == userId ||
              userId == request.auth.uid
            )
          ) ||
          (
            request.resource.data.type == 'media-comment'
            && userId == request.auth.uid
            && request.resource.data.targetUserUid == request.auth.uid
            && hasValidActivityMediaFields()
          )
        );
    }

    function isValidMediaCommentCreate(tripId, folderId, itemId) {
      return isMember()
        && request.resource.data.id is string
        && request.resource.data.type == 'media-comment'
        && hasValidSocialContent()
        && hasValidMediaCommentAuthorFields()
        && request.resource.data.tripId == tripId
        && request.resource.data.folderId == folderId
        && request.resource.data.itemId == itemId
        && request.resource.data.itemName is string
        && request.resource.data.sourceLabel is string
        && request.resource.data.createdAtMs is number
        && request.resource.data.createdAtMs > 0;
    }

    function isValidSocialCommentEdit() {
      return hasValidSocialContent()
        && request.resource.data.editedAtMs is number
        && request.resource.data.updatedAtMs is number
        && request.resource.data.editedAtMs > 0
        && request.resource.data.updatedAtMs > 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'body',
          'editedAt',
          'editedAtMs',
          'updatedAt',
          'updatedAtMs'
        ]);
    }

    function isValidActivityMediaCommentUpdate() {
      return isMember()
        && resource.data.type == 'media-comment'
        && resource.data.actorUid == request.auth.uid
        && request.resource.data.type == resource.data.type
        && request.resource.data.actorUid == resource.data.actorUid
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.folderId == resource.data.folderId
        && request.resource.data.itemId == resource.data.itemId
        && isValidSocialCommentEdit();
    }

    function isValidMediaCommentUpdate() {
      return isMember()
        && resource.data.type == 'media-comment'
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.type == resource.data.type
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.folderId == resource.data.folderId
        && request.resource.data.itemId == resource.data.itemId
        && isValidSocialCommentEdit();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidSelfCreate(userId);
      allow update: if isSignedIn()
        && (
          (request.auth.uid == userId && isValidSelfUpdate()) ||
          (isAdmin() && isValidAdminUpdate(userId))
        );
      allow delete: if isAdmin();

      match /activity/{activityId} {
        allow read: if true;
        allow create: if isValidActivityCreate(userId);
        allow update: if isValidActivityMediaCommentUpdate();
        allow delete: if isAdmin()
          || (isMember() && resource.data.actorUid == request.auth.uid)
          || (isMember() && userId == request.auth.uid && resource.data.type == 'wall-post');
      }
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSiteSettings();
      allow delete: if isAdmin();
    }

    match /trips/{tripId} {
      allow read: if request.auth == null || isMember();
      allow create, update, delete: if isAdmin();

      match /folders/{folderId} {
        allow read: if request.auth == null || isMember();
        allow create, update, delete: if isAdmin();

        match /items/{itemId} {
          allow read: if request.auth == null || isMember();
          allow create: if isAdmin() || isValidMemberMediaCreate() || isValidMemberTextCreate();
          allow update: if isAdmin() || isValidMemberTextUpdate() || isValidMemberFileUpdate();
          allow delete: if isAdmin() || isItemOwner();

          match /comments/{commentId} {
            allow read: if request.auth == null || isMember();
            allow create: if isValidMediaCommentCreate(tripId, folderId, itemId);
            allow update: if isValidMediaCommentUpdate();
            allow delete: if isAdmin()
              || (isMember() && resource.data.authorUid == request.auth.uid);
          }
        }
      }
    }
  }
}
